---
const WA_LINK = "https://wa.me/5548998386116?text=Ol%C3%A1!%20Gostaria%20de%20agendar%20uma%20demonstra%C3%A7%C3%A3o%20do%20BOT%20BigWorks";
---

<section class="py-32 relative overflow-hidden">
  <!-- Gradient background -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 50% at 50% 50%, rgba(99,102,241,0.12) 0%, transparent 70%);"></div>
  <div class="orb w-96 h-96 opacity-15" style="background: radial-gradient(circle, #6366f1, transparent); top: -20%; left: -10%;"></div>
  <div class="orb w-80 h-80 opacity-10" style="background: radial-gradient(circle, #06b6d4, transparent); bottom: -20%; right: -10%;"></div>

  <!-- Top border glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-64 h-px" style="background: linear-gradient(90deg, transparent, #6366f1, transparent);"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
    <div class="section-tag mb-8 mx-auto" style="width: fit-content;">Pronto para começar?</div>

    <h2 style="font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(1.75rem, 3vw, 2.625rem); letter-spacing: -0.03em; color: #f1f5f9; line-height: 1.1; margin-bottom: 1.5rem;">
      Transforme o WhatsApp da sua empresa em uma
      <span class="gradient-text"> central inteligente de atendimento.</span>
    </h2>

    <p style="color: #94a3b8; font-size: 1.125rem; line-height: 1.7; max-width: 520px; margin: 0 auto 2.5rem;">
      Automatize processos, reduza tempo perdido e melhore a experiência do cliente — começando agora.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary" style="font-size: 1rem; padding: 1rem 2rem;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.853L.044 23.956 6.303 22.5A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.032-1.387l-.36-.214-3.732.979 1-3.63-.234-.373A9.818 9.818 0 0112 2.182c5.427 0 9.818 4.391 9.818 9.818 0 5.428-4.391 9.818-9.818 9.818z"/>
        </svg>
        Agendar demonstração
      </a>
      <a href="#planos" class="btn-secondary" style="font-size: 1rem; padding: 1rem 2rem;">
        Ver planos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Social proof -->
    <div class="flex items-center justify-center gap-6 mt-10 flex-wrap">
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#10b981" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
        <span style="font-size: 0.875rem; color: #64748b;">Sem contrato mínimo</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#10b981" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
        <span style="font-size: 0.875rem; color: #64748b;">Setup assistido</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#10b981" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
        <span style="font-size: 0.875rem; color: #64748b;">Suporte em português</span>
      </div>
    </div>
  </div>
</section>
