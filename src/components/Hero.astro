---
const WA_LINK = "https://wa.me/5548998386116?text=Ol%C3%A1!%20Gostaria%20de%20saber%20mais%20sobre%20o%20BOT%20BigWorks";
---

<section class="relative min-h-screen flex items-center pt-24 pb-20 overflow-hidden">
  <!-- Background orbs -->
  <div class="orb w-96 h-96 opacity-20" style="background: radial-gradient(circle, #6366f1, transparent); top: 10%; left: -10%;"></div>
  <div class="orb w-80 h-80 opacity-15" style="background: radial-gradient(circle, #3b82f6, transparent); top: 30%; right: -5%;"></div>
  <div class="orb w-64 h-64 opacity-10" style="background: radial-gradient(circle, #06b6d4, transparent); bottom: 10%; left: 30%;"></div>

  <!-- Grid background -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-5 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Left: copy -->
    <div>
      <div class="section-tag mb-6">
        <span style="width:6px;height:6px;border-radius:50%;background:#06b6d4;display:inline-block;"></span>
        Inteligência artificial para operações reais
      </div>

      <h1 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.875rem, 3.25vw, 2.75rem); line-height: 1.15; letter-spacing: -0.025em; color: #f1f5f9; margin-bottom: 1.5rem;">
        Seu WhatsApp respondendo clientes, consultando sistemas e
        <span class="gradient-text"> executando ações. Automaticamente.</span>
      </h1>

      <p style="color: #94a3b8; font-size: 1.125rem; line-height: 1.7; max-width: 480px; margin-bottom: 2.5rem;">
        IA integrada à operação da empresa — atende, consulta, encaminha e executa ações reais. Texto, áudio, imagem e PDF em um único fluxo.
      </p>

      <div class="flex flex-wrap gap-3 mb-10">
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.853L.044 23.956 6.303 22.5A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.032-1.387l-.36-.214-3.732.979 1-3.63-.234-.373A9.818 9.818 0 0112 2.182c5.427 0 9.818 4.391 9.818 9.818 0 5.428-4.391 9.818-9.818 9.818z"/>
          </svg>
          Quero uma demonstração
        </a>
        <a href="#funcionalidades" class="btn-secondary">
          Ver funcionalidades
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex flex-wrap gap-3">
        <div class="icon-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#25d366" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.853L.044 23.956 6.303 22.5A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.032-1.387l-.36-.214-3.732.979 1-3.63-.234-.373A9.818 9.818 0 0112 2.182c5.427 0 9.818 4.391 9.818 9.818 0 5.428-4.391 9.818-9.818 9.818z"/></svg>
          WhatsApp nativo
        </div>
        <div class="icon-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          IA multimodal
        </div>
        <div class="icon-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          Integra com ERP/API
        </div>
        <div class="icon-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          Atendimento 24h
        </div>
      </div>
    </div>

    <!-- Right: WhatsApp mockup -->
    <div class="flex justify-center lg:justify-end">
      <div class="relative w-full max-w-sm">
        <!-- Phone frame -->
        <div class="relative rounded-3xl overflow-hidden shadow-2xl" style="background: #111318; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 40px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.05), inset 0 1px 0 rgba(255,255,255,0.1);">

          <!-- WhatsApp header -->
          <div class="px-4 py-3 flex items-center gap-3" style="background: #1a1f2e; border-bottom: 1px solid rgba(255,255,255,0.06);">
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold" style="background: linear-gradient(135deg, #6366f1, #3b82f6); font-family: 'Plus Jakarta Sans', sans-serif; color: white;">B</div>
            <div class="flex-1">
              <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.875rem; color: #f1f5f9;">BOT BigWorks</div>
              <div style="font-size: 0.6875rem; color: #25d366; display: flex; align-items: center; gap: 3px;">
                <span style="width:5px;height:5px;border-radius:50%;background:#25d366;display:inline-block;"></span>
                online agora
              </div>
            </div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
          </div>

          <!-- Chat area -->
          <div class="p-4 space-y-3" style="background: #0d1117; min-height: 380px;">

            <!-- Client: text message -->
            <div class="wpp-msg flex justify-end">
              <div class="max-w-xs rounded-2xl rounded-tr-sm px-3.5 py-2.5" style="background: #1e3a5f;">
                <p style="font-size: 0.8125rem; color: #e2e8f0; line-height: 1.5;">Minha Amarok já ficou pronta?</p>
                <div style="font-size: 0.625rem; color: #94a3b8; text-align: right; margin-top: 4px; display: flex; align-items: center; justify-content: flex-end; gap: 3px;">
                  09:14
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#06b6d4" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                </div>
              </div>
            </div>

            <!-- Bot: locating -->
            <div class="wpp-msg flex gap-2">
              <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs" style="background: linear-gradient(135deg, #6366f1, #3b82f6); font-family: 'Plus Jakarta Sans'; font-weight: 700; color: white; margin-top: 2px;">B</div>
              <div class="max-w-xs rounded-2xl rounded-tl-sm px-3.5 py-2.5" style="background: #1a1f2e;">
                <p style="font-size: 0.8125rem; color: #e2e8f0; line-height: 1.5;">Localizando veículo no sistema...</p>
                <div style="font-size: 0.625rem; color: #64748b; margin-top: 4px;">09:14</div>
              </div>
            </div>

            <!-- Bot: OS found card -->
            <div class="wpp-msg flex gap-2">
              <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs opacity-0" style="background: linear-gradient(135deg, #6366f1, #3b82f6);"></div>
              <div class="max-w-xs rounded-2xl rounded-tl-sm px-3.5 py-2.5" style="background: #1a1f2e; border: 1px solid rgba(99,102,241,0.2);">
                <div style="font-size: 0.625rem; color: #6366f1; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">OS #4872 — AMAROK</div>
                <p style="font-size: 0.8125rem; color: #e2e8f0; line-height: 1.5;">Serviço concluído. Veículo <strong>pronto para retirada</strong>.</p>
                <div style="margin-top: 8px; padding: 6px 8px; border-radius: 6px; background: rgba(37,211,102,0.1); border: 1px solid rgba(37,211,102,0.2);">
                  <p style="font-size: 0.6875rem; color: #25d366; font-weight: 600;">Disponível a partir das 08h</p>
                </div>
                <div style="font-size: 0.625rem; color: #64748b; margin-top: 4px;">09:14</div>
              </div>
            </div>

            <!-- Client: audio message -->
            <div class="wpp-msg flex justify-end">
              <div class="max-w-xs rounded-2xl rounded-tr-sm px-3.5 py-2.5" style="background: #1e3a5f; display: flex; align-items: center; gap: 10px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#06b6d4" aria-hidden="true"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2" fill="none" stroke="#06b6d4" stroke-width="2"/><line x1="12" y1="19" x2="12" y2="23" stroke="#06b6d4" stroke-width="2"/><line x1="8" y1="23" x2="16" y2="23" stroke="#06b6d4" stroke-width="2"/></svg>
                <div class="waveform">
                  <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
                <span style="font-size: 0.6875rem; color: #94a3b8;">0:12</span>
              </div>
            </div>

            <!-- Bot: transcription -->
            <div class="wpp-msg flex gap-2">
              <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs" style="background: linear-gradient(135deg, #6366f1, #3b82f6); font-family: 'Plus Jakarta Sans'; font-weight: 700; color: white; margin-top: 2px;">B</div>
              <div class="max-w-xs rounded-2xl rounded-tl-sm px-3.5 py-2.5" style="background: #1a1f2e;">
                <div style="font-size: 0.625rem; color: #06b6d4; font-weight: 600; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.04em;">Áudio transcrito</div>
                <p style="font-size: 0.8125rem; color: #94a3b8; font-style: italic; line-height: 1.5;">"quero remarcar para terça-feira"</p>
                <div style="font-size: 0.625rem; color: #64748b; margin-top: 4px;">09:15</div>
              </div>
            </div>

            <!-- Bot: pre-booking created -->
            <div class="wpp-msg flex gap-2">
              <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs opacity-0" style="background: linear-gradient(135deg, #6366f1, #3b82f6);"></div>
              <div class="max-w-xs rounded-2xl rounded-tl-sm px-3.5 py-2.5" style="background: #1a1f2e;">
                <p style="font-size: 0.8125rem; color: #e2e8f0; line-height: 1.5;">Pré-agendamento criado para <strong>terça-feira</strong>. A equipe vai confirmar em breve.</p>
                <div style="font-size: 0.625rem; color: #64748b; margin-top: 4px;">09:15</div>
              </div>
            </div>

          </div>
        </div>

        <!-- Floating badges -->
        <div class="absolute -left-10 top-16 icon-badge shadow-xl" style="background: rgba(13,17,23,0.9); border-color: rgba(99,102,241,0.3); animation: float 4s ease-in-out infinite;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" aria-hidden="true"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          OCR ativo
        </div>
        <div class="absolute -right-10 bottom-24 icon-badge shadow-xl" style="background: rgba(13,17,23,0.9); border-color: rgba(6,182,212,0.3); animation: float 4s ease-in-out infinite 2s;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          ERP consultado
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
</style>
