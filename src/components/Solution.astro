---
---

<section class="py-24 relative overflow-hidden">
  <!-- Subtle gradient separator -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(99,102,241,0.04) 0%, rgba(59,130,246,0.03) 50%, transparent 100%);"></div>
  <div class="orb w-96 h-96 opacity-10" style="background: radial-gradient(circle, #6366f1, transparent); top: 20%; right: -15%;"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <div class="section-tag mb-6" style="width: fit-content;">A solução</div>
        <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: #f1f5f9; line-height: 1.15; margin-bottom: 1.5rem;">
          Um atendente IA conectado à
          <span class="gradient-text"> operação da empresa.</span>
        </h2>
        <p style="color: #94a3b8; font-size: 1.0625rem; line-height: 1.75; margin-bottom: 1.25rem;">
          O sistema interpreta mensagens em linguagem natural e executa ações reais no fluxo operacional da empresa.
        </p>
        <p style="color: #64748b; font-size: 1rem; line-height: 1.75; padding-left: 1rem; border-left: 2px solid rgba(99,102,241,0.4);">
          Não é apenas um chatbot.<br/>
          É uma camada inteligente integrada ao WhatsApp e aos sistemas internos.
        </p>
      </div>

      <!-- Right: capability grid -->
      <div class="grid grid-cols-2 gap-3">
        {[
          { label: "Linguagem natural", icon: "💬", color: "#6366f1" },
          { label: "Áudio e voz", icon: "🎙️", color: "#3b82f6" },
          { label: "Leitura de imagens", icon: "🖼️", color: "#06b6d4" },
          { label: "OCR em documentos", icon: "📄", color: "#8b5cf6" },
          { label: "Integração com ERP", icon: "⚙️", color: "#f59e0b" },
          { label: "Ações operacionais", icon: "⚡", color: "#ec4899" },
        ].map((item) => (
          <div class="glass-card p-4 flex items-center gap-3 reveal" style={`border-color: rgba(${item.color === '#6366f1' ? '99,102,241' : item.color === '#3b82f6' ? '59,130,246' : item.color === '#06b6d4' ? '6,182,212' : item.color === '#8b5cf6' ? '139,92,246' : item.color === '#f59e0b' ? '245,158,11' : '236,72,153'},0.15);`}>
            <span style="font-size: 1.25rem;" aria-hidden="true">{item.icon}</span>
            <span style={`font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 600; font-size: 0.875rem; color: #e2e8f0;`}>{item.label}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
