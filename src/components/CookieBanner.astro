---
---

<div
  id="cookie-banner"
  role="dialog"
  aria-label="Aviso de cookies"
  aria-live="polite"
  style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:9999; background:rgba(var(--rgb-surface-tint), 0.97); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border-top:1px solid rgba(var(--rgb-surface-on-dark), 0.08); box-shadow:0 -8px 40px rgba(0,0,0,0.4);"
>
  <div style="max-width:72rem; margin:0 auto; padding:1.25rem 1.25rem; display:flex; flex-direction:column; gap:1rem;">
    <div style="display:flex; flex-direction:column; gap:0.875rem;">
      <div style="display:flex; align-items:flex-start; gap:0.75rem;">
        <div style="width:2rem; height:2rem; border-radius:0.5rem; background:rgba(99,102,241,0.15); border:1px solid rgba(99,102,241,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <p style="font-family:'Plus Jakarta Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:var(--color-text-primary); margin-bottom:0.375rem;">Privacidade e cookies</p>
          <p style="font-size:0.875rem; color:var(--color-text-muted); line-height:1.6;">
            Usamos cookies essenciais para o funcionamento do site e, com seu consentimento, cookies de análise (Google Analytics) para entender como o site é usado. Seus dados são tratados conforme nossa
            <a href="/privacidade" style="color:var(--color-text-secondary); text-decoration:underline;">Política de Privacidade</a>
            e a <strong style="color:var(--color-text-secondary);">LGPD (Lei 13.709/2018)</strong>.
          </p>
        </div>
      </div>

      <div style="display:flex; flex-wrap:wrap; gap:0.625rem; padding-left:2.75rem;">
        <button
          id="cookie-essential"
          style="padding:0.5rem 1rem; border-radius:0.5rem; border:1px solid rgba(var(--rgb-surface-on-dark), 0.1); background:transparent; color:var(--color-text-secondary); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; cursor:pointer; transition:all 0.2s; white-space:nowrap;"
          onmouseover="this.style.borderColor='rgba(99,102,241,0.4)';this.style.color='var(--color-text-primary)'"
          onmouseout="this.style.borderColor='rgba(var(--rgb-surface-on-dark), 0.1)';this.style.color='var(--color-text-secondary)'"
        >
          Somente essenciais
        </button>
        <button
          id="cookie-accept-all"
          style="padding:0.5rem 1rem; border-radius:0.5rem; border:none; background:linear-gradient(135deg,#6366f1,#3b82f6); color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:700; cursor:pointer; transition:opacity 0.2s; white-space:nowrap;"
          onmouseover="this.style.opacity='0.88'"
          onmouseout="this.style.opacity='1'"
        >
          Aceitar todos
        </button>
        <a
          href="/privacidade"
          style="display:inline-flex; align-items:center; padding:0.5rem 1rem; color:var(--color-text-faint); font-size:0.8125rem; text-decoration:none; white-space:nowrap; transition:color 0.2s;"
          onmouseover="this.style.color='var(--color-text-secondary)'"
          onmouseout="this.style.color='var(--color-text-faint)'"
        >
          Saber mais
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = 'botbigworks_cookie_consent';

  function initGA() {
    // @ts-ignore
    if (typeof window.gtag === 'function') {
      window.gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  }

  function showBanner() {
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'block';
  }

  function hideBanner() {
    const banner = document.getElementById('cookie-banner');
    if (banner) {
      banner.style.opacity = '0';
      banner.style.transition = 'opacity 0.3s';
      setTimeout(() => { banner.style.display = 'none'; }, 300);
    }
  }

  function accept(level: string) {
    localStorage.setItem(CONSENT_KEY, level);
    if (level === 'all') initGA();
    hideBanner();
  }

  const stored = localStorage.getItem(CONSENT_KEY);
  if (!stored) {
    showBanner();
  } else if (stored === 'all') {
    initGA();
  }

  document.getElementById('cookie-essential')?.addEventListener('click', () => accept('essential'));
  document.getElementById('cookie-accept-all')?.addEventListener('click', () => accept('all'));
</script>
