---
const problems = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    color: "#f59e0b",
    bg: "rgba(245,158,11,0.08)",
    border: "rgba(245,158,11,0.15)",
    title: "Atendimento repetitivo",
    text: "Horário, endereço, orçamento, status e agendamentos simples consomem tempo da equipe todos os dias.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2" fill="none"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
    color: "#ec4899",
    bg: "rgba(236,72,153,0.08)",
    border: "rgba(236,72,153,0.15)",
    title: "Áudios longos sem resposta",
    text: "Clientes mandam minutos de áudio e ninguém na equipe quer parar tudo para ouvir cada mensagem.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
    color: "#ef4444",
    bg: "rgba(239,68,68,0.08)",
    border: "rgba(239,68,68,0.15)",
    title: "Leads perdidos fora do horário",
    text: "Mensagens que chegam à noite ou nos finais de semana ficam sem resposta — e o cliente vai embora.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>`,
    color: "#8b5cf6",
    bg: "rgba(139,92,246,0.08)",
    border: "rgba(139,92,246,0.15)",
    title: "Informações desorganizadas",
    text: "Dados espalhados entre WhatsApp, papel e memória dos funcionários. Ninguém sabe o status de nada.",
  },
];
---

<section class="py-24 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-14">
      <div class="section-tag mb-5 mx-auto" style="width: fit-content;">O problema</div>
      <h2 style="font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: #f1f5f9; line-height: 1.15;">
        Sua empresa perde tempo respondendo<br/>
        <span class="gradient-text">as mesmas coisas todos os dias.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {problems.map((p) => (
        <div class="glass-card p-6 hover:border-white/10 transition-all duration-300 reveal" style={`border-color: ${p.border};`}>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style={`background: ${p.bg}; color: ${p.color}; border: 1px solid ${p.border};`}>
              <Fragment set:html={p.icon} />
            </div>
            <div>
              <h3 style={`font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: ${p.color}; margin-bottom: 0.5rem;`}>{p.title}</h3>
              <p style="color: #94a3b8; font-size: 0.9375rem; line-height: 1.65;">{p.text}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
