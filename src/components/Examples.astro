---
const examples = [
  {
    number: "01",
    title: "Consulta de status",
    client: "Minha Amarok já ficou pronta?",
    clientType: "text",
    steps: [
      { icon: "🔍", text: "Localiza o veículo no cadastro" },
      { icon: "📋", text: "Consulta a ordem de serviço" },
      { icon: "✅", text: "Responde com o status atual" },
    ],
    color: "#6366f1",
  },
  {
    number: "02",
    title: "Áudio + foto do veículo",
    client: "Áudio de voz + foto do carro",
    clientType: "media",
    steps: [
      { icon: "🎙️", text: "Transcreve o áudio automaticamente" },
      { icon: "🔢", text: "Identifica a placa pela foto (OCR)" },
      { icon: "📅", text: "Abre um pré-agendamento no sistema" },
    ],
    color: "#3b82f6",
  },
  {
    number: "03",
    title: "PDF para orçamento",
    client: "Gostaria de orçamento",
    clientType: "pdf",
    steps: [
      { icon: "📄", text: "Lê o documento enviado" },
      { icon: "📝", text: "Resume as informações relevantes" },
      { icon: "➡️", text: "Encaminha para o financeiro" },
    ],
    color: "#06b6d4",
  },
];
---

<section class="py-24 relative overflow-hidden">
  <div class="orb w-96 h-96 opacity-10" style="background: radial-gradient(circle, #3b82f6, transparent); bottom: 0; left: -10%;"></div>

  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-14">
      <div class="section-tag mb-5 mx-auto" style="width: fit-content;">Exemplos reais</div>
      <h2 style="font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: #f1f5f9; line-height: 1.15;">
        Veja como funciona
        <span class="gradient-text"> na prática.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {examples.map((ex) => (
        <div class="glass-card p-6 flex flex-col gap-5 reveal">
          <div class="flex items-center justify-between">
            <span style={`font-family: 'Syne', sans-serif; font-size: 2.5rem; font-weight: 800; color: ${ex.color}; opacity: 0.3; line-height: 1;`}>{ex.number}</span>
            <span style={`font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9375rem; color: ${ex.color};`}>{ex.title}</span>
          </div>

          <!-- Client message preview -->
          <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 0.75rem; padding: 0.875rem;">
            <div style="font-size: 0.6875rem; color: #475569; font-weight: 600; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Cliente envia</div>
            <div class="flex items-center gap-2">
              {ex.clientType === 'text' && (
                <>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                  <span style="font-size: 0.875rem; color: #94a3b8; font-style: italic;">"{ex.client}"</span>
                </>
              )}
              {ex.clientType === 'media' && (
                <>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#06b6d4" aria-hidden="true"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2" fill="none" stroke="#06b6d4" stroke-width="2"/></svg>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
                  <span style="font-size: 0.875rem; color: #94a3b8;">{ex.client}</span>
                </>
              )}
              {ex.clientType === 'pdf' && (
                <>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
                  <span style="font-size: 0.875rem; color: #94a3b8;">PDF + "{ex.client}"</span>
                </>
              )}
            </div>
          </div>

          <!-- Bot response steps -->
          <div class="flex flex-col gap-2.5">
            <div style="font-size: 0.6875rem; color: #475569; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Bot executa</div>
            {ex.steps.map((step, i) => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0 text-xs" style={`background: ${ex.color}14; border: 1px solid ${ex.color}22;`}>
                  <span aria-hidden="true">{step.icon}</span>
                </div>
                <span style="font-size: 0.875rem; color: #94a3b8; line-height: 1.5;">{step.text}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
