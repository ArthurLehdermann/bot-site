---
// public_key não é segredo (é uma "publishable key", como em Stripe) — pode
// ficar hardcoded. Em produção, ajustar WIDGET_API_URL para o domínio real da
// API do bot (e WIDGET_PUBLIC_KEY se o tenant "bigworks" for re-seedado em prod
// com uma chave diferente).
const WIDGET_API_URL = import.meta.env.DEV ? 'http://localhost' : 'https://bot.bigworks.com.br';
const WIDGET_TENANT_SLUG = 'bigworks';
const WIDGET_PUBLIC_KEY = 'wpk_KullKMhGHWeEeOXgjOgQn4meTCdaxTsQ';
const WIDGET_ENDPOINT = `${WIDGET_API_URL}/api/widget/${WIDGET_TENANT_SLUG}/message`;
const WIDGET_LEAD_ENDPOINT = `${WIDGET_API_URL}/api/widget/${WIDGET_TENANT_SLUG}/lead`;

// Site key do Cloudflare Turnstile (widget "BOT BigWorks") — não é segredo,
// fica visível no HTML.
const TURNSTILE_SITE_KEY = '0x4AAAAAADkjYXdKcaeLLV-H';

const WA_LINK = 'https://wa.me/5548998386116?text=Ol%C3%A1!%20Gostaria%20de%20saber%20mais%20sobre%20o%20BOT%20BigWorks';
const GREETING = 'Olá! Este chat usa o próprio BOT BigWorks funcionando em produção. Pode perguntar qualquer coisa sobre o produto.';
const ERROR_REPLY = `Não consegui responder agora. Tenta de novo ou fala com a gente pelo WhatsApp: ${WA_LINK}`;
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<div id="cw-root" data-endpoint={WIDGET_ENDPOINT} data-lead-endpoint={WIDGET_LEAD_ENDPOINT} data-public-key={WIDGET_PUBLIC_KEY} data-greeting={GREETING} data-error-reply={ERROR_REPLY}>
  <div id="cw-fab-label" aria-hidden="true">Testar agora</div>
  <script is:inline>
    // Roda de forma síncrona antes do paint para evitar flash do label
    // (a chave deve ficar igual a LABEL_DISMISSED_KEY no script principal abaixo).
    if (localStorage.getItem('bw_chat_label_dismissed')) {
      document.getElementById('cw-fab-label').style.display = 'none';
    }
  </script>
  <button id="cw-fab" type="button" aria-label="Abrir chat" aria-expanded="false" aria-controls="cw-panel">
    <div id="cw-fab-icons">
      <svg class="cw-fab-icon cw-fab-icon-active" data-variant="logo" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
      <svg class="cw-fab-icon" data-variant="whatsapp" width="24" height="24" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.853L.044 23.956 6.303 22.5A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.032-1.387l-.36-.214-3.732.979 1-3.63-.234-.373A9.818 9.818 0 0112 2.182c5.427 0 9.818 4.391 9.818 9.818 0 5.428-4.391 9.818-9.818 9.818z"/>
      </svg>
      <svg class="cw-fab-icon" data-variant="telegram" width="24" height="24" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
        <path d="M22.05 2.04 2.7 9.74c-1.3.52-1.29 1.25-.24 1.58l4.95 1.55 1.92 6.18c.24.66.43.9.86.9.4 0 .59-.18.82-.4l2.3-2.23 4.78 3.53c.88.49 1.5.24 1.72-.81L23.9 3.5c.31-1.28-.49-1.86-1.85-1.46zM8.5 14.06l9.66-6.1c.46-.28.88-.13.53.18l-8.27 7.46-.32 3.4-1.6-4.94z"/>
      </svg>
    </div>
    <svg id="cw-fab-icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <div id="cw-panel" role="dialog" aria-modal="true" aria-label="Chat com BOT BigWorks" hidden>
    <div id="cw-header">
      <div id="cw-avatar">B</div>
      <div id="cw-header-text">
        <div id="cw-header-title">BOT BigWorks</div>
        <div id="cw-header-status"><span id="cw-status-dot"></span>online agora</div>
      </div>
      <button id="cw-close" type="button" aria-label="Fechar chat">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div id="cw-lead-gate">
      <p id="cw-lead-intro">Antes de começar, me conta seu nome e um WhatsApp ou e-mail para contato. Assim, se precisar de um humano, a equipe consegue te chamar.</p>
      <form id="cw-lead-form">
        <label class="cw-lead-label" for="cw-lead-name">Nome</label>
        <input id="cw-lead-name" type="text" autocomplete="name" placeholder="Seu nome" required />
        <label class="cw-lead-label" for="cw-lead-phone">WhatsApp</label>
        <input id="cw-lead-phone" type="tel" autocomplete="tel" placeholder="(48) 99999-9999" />
        <label class="cw-lead-label" for="cw-lead-email">E-mail</label>
        <input id="cw-lead-email" type="email" autocomplete="email" placeholder="seu@email.com" />
        <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="auto"></div>
        <div id="cw-lead-error" role="alert"></div>
        <button id="cw-lead-submit" type="submit">Começar conversa</button>
      </form>
    </div>

    <div id="cw-messages" role="log" aria-live="polite" hidden></div>

    <div id="cw-input-area" hidden>
      <textarea id="cw-input" rows="1" placeholder="Escreva sua mensagem..." aria-label="Mensagem"></textarea>
      <button id="cw-send" type="button" aria-label="Enviar mensagem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  #cw-root {
    --cw-bg: var(--color-mockup-chat-bg);
    --cw-header-bg: var(--color-mockup-header);
    --cw-bubble-bot: var(--color-bubble-bot);
    --cw-bubble-user: var(--color-bubble-client);
    --cw-text-primary: var(--color-text-primary);
    --cw-text-muted: var(--color-text-muted);
    --cw-accent-a: var(--color-accent);
    --cw-accent-b: var(--color-accent-blue);
    font-family: 'DM Sans', sans-serif;
  }

  #cw-fab {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--cw-accent-a), var(--cw-accent-b));
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.4);
    transition: transform 0.15s ease, opacity 0.15s ease;
    animation: cw-pulse 2.4s ease-out 1s 3;
  }
  #cw-fab:hover {
    transform: scale(1.06);
  }
  #cw-fab:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  @keyframes cw-pulse {
    0% { box-shadow: 0 8px 24px rgba(99, 102, 241, 0.4), 0 0 0 0 rgba(99, 102, 241, 0.5); }
    70% { box-shadow: 0 8px 24px rgba(99, 102, 241, 0.4), 0 0 0 14px rgba(99, 102, 241, 0); }
    100% { box-shadow: 0 8px 24px rgba(99, 102, 241, 0.4), 0 0 0 0 rgba(99, 102, 241, 0); }
  }

  #cw-fab-icons {
    position: relative;
    width: 26px;
    height: 26px;
  }
  .cw-fab-icon {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(0.7) rotate(-15deg);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .cw-fab-icon.cw-fab-icon-active {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  #cw-fab-label {
    position: fixed;
    right: 5.375rem;
    bottom: 1.85rem;
    z-index: 9998;
    background: var(--cw-header-bg);
    color: var(--cw-text-primary);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.8125rem;
    white-space: nowrap;
    padding: 0.5rem 0.875rem;
    border-radius: 999px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(var(--rgb-surface-on-dark), 0.06);
    animation: cw-label-bounce 2.6s ease-in-out 1s infinite;
  }
  #cw-fab-label::after {
    content: '';
    position: absolute;
    right: -5px;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: var(--cw-header-bg);
  }
  @keyframes cw-label-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
  @media (max-width: 480px) {
    #cw-fab-label {
      right: 4.875rem;
      font-size: 0.75rem;
      padding: 0.4375rem 0.75rem;
    }
  }

  #cw-panel {
    position: fixed;
    right: 1.25rem;
    bottom: 5.5rem;
    width: 360px;
    height: 520px;
    max-height: calc(100dvh - 7rem);
    background: var(--cw-bg);
    border-radius: 1rem;
    box-shadow: var(--shadow-mockup);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  #cw-panel[hidden] {
    display: none;
  }

  @media (max-width: 480px) {
    #cw-panel {
      inset: 0;
      width: 100%;
      height: 100dvh;
      max-height: none;
      border-radius: 0;
    }

    #cw-header {
      padding-top: calc(0.875rem + env(safe-area-inset-top));
    }

    #cw-input-area {
      padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));
    }

    #cw-root.cw-panel-open #cw-fab {
      display: none;
    }

    /* 16px evita o zoom automático do iOS Safari ao focar campos */
    #cw-lead-name,
    #cw-lead-phone,
    #cw-lead-email,
    #cw-input {
      font-size: 1rem;
    }
  }

  #cw-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--cw-header-bg);
    border-bottom: 1px solid rgba(var(--rgb-surface-on-dark), 0.06);
  }
  #cw-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: #fff;
    background: linear-gradient(135deg, var(--cw-accent-a), var(--cw-accent-b));
  }
  #cw-header-text {
    flex: 1;
    min-width: 0;
  }
  #cw-header-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--cw-text-primary);
  }
  #cw-header-status {
    font-size: 0.6875rem;
    color: #25d366;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  #cw-status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #25d366;
    display: inline-block;
  }
  #cw-close {
    flex-shrink: 0;
    border: none;
    background: transparent;
    color: var(--cw-text-muted);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, background 0.15s ease;
  }
  #cw-close:hover {
    color: var(--cw-text-primary);
    background: rgba(var(--rgb-surface-on-dark), 0.06);
  }
  #cw-close:focus-visible,
  #cw-send:focus-visible,
  #cw-input:focus-visible {
    outline: 2px solid var(--cw-accent-a);
    outline-offset: 1px;
  }

  #cw-lead-gate {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem;
  }
  #cw-lead-gate[hidden] {
    display: none;
  }
  #cw-lead-intro {
    margin: 0 0 0.25rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--cw-text-primary);
  }
  #cw-lead-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cw-lead-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--cw-text-muted);
  }
  #cw-lead-name,
  #cw-lead-phone,
  #cw-lead-email {
    border: 1px solid rgba(var(--rgb-surface-on-dark), 0.1);
    border-radius: 0.75rem;
    background: var(--cw-bg);
    color: var(--cw-text-primary);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    line-height: 1.4;
    padding: 0.625rem 0.75rem;
  }
  #cw-lead-name::placeholder,
  #cw-lead-phone::placeholder,
  #cw-lead-email::placeholder {
    color: var(--cw-text-muted);
  }
  #cw-lead-name:focus-visible,
  #cw-lead-phone:focus-visible,
  #cw-lead-email:focus-visible,
  #cw-lead-submit:focus-visible {
    outline: 2px solid var(--cw-accent-a);
    outline-offset: 1px;
  }
  .cf-turnstile {
    margin-top: 0.25rem;
  }
  #cw-lead-error {
    min-height: 1em;
    font-size: 0.75rem;
    color: #ef4444;
  }
  #cw-lead-submit {
    margin-top: 0.25rem;
    border: none;
    border-radius: 0.75rem;
    padding: 0.625rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.8125rem;
    color: #fff;
    cursor: pointer;
    background: linear-gradient(135deg, var(--cw-accent-a), var(--cw-accent-b));
    transition: opacity 0.15s ease;
  }
  #cw-lead-submit:hover {
    opacity: 0.88;
  }

  #cw-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  #cw-messages[hidden] {
    display: none;
  }
  #cw-input-area[hidden] {
    display: none;
  }

  .cw-msg {
    display: flex;
    gap: 0.5rem;
    max-width: 85%;
  }
  .cw-msg.cw-msg-bot {
    align-self: flex-start;
  }
  .cw-msg.cw-msg-user {
    align-self: flex-end;
  }
  .cw-bubble {
    border-radius: 1rem;
    padding: 0.625rem 0.875rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--cw-text-primary);
    white-space: pre-wrap;
    word-break: break-word;
  }
  .cw-msg-bot .cw-bubble {
    background: var(--cw-bubble-bot);
    border-top-left-radius: 0.25rem;
  }
  .cw-msg-user .cw-bubble {
    background: var(--cw-bubble-user);
    border-top-right-radius: 0.25rem;
  }
  .cw-typing {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 0.75rem 0.875rem;
    background: var(--cw-bubble-bot);
    border-radius: 1rem;
    border-top-left-radius: 0.25rem;
  }
  .cw-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cw-text-muted);
    animation: cw-typing-bounce 1.2s infinite ease-in-out;
  }
  .cw-typing span:nth-child(2) { animation-delay: 0.15s; }
  .cw-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes cw-typing-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  #cw-input-area {
    flex-shrink: 0;
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    padding: 0.75rem;
    border-top: 1px solid rgba(var(--rgb-surface-on-dark), 0.06);
    background: var(--cw-header-bg);
  }
  #cw-input {
    flex: 1;
    resize: none;
    max-height: 6.5rem;
    border: 1px solid rgba(var(--rgb-surface-on-dark), 0.1);
    border-radius: 0.75rem;
    background: var(--cw-bg);
    color: var(--cw-text-primary);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    line-height: 1.4;
    padding: 0.625rem 0.75rem;
  }
  #cw-input::placeholder {
    color: var(--cw-text-muted);
  }
  #cw-input:disabled,
  #cw-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  #cw-send {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.75rem;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: linear-gradient(135deg, var(--cw-accent-a), var(--cw-accent-b));
    transition: opacity 0.15s ease;
  }
  #cw-send:hover:not(:disabled) {
    opacity: 0.88;
  }
</style>

<script>
  const root = document.getElementById('cw-root') as HTMLElement;
  const endpoint = root.dataset.endpoint as string;
  const leadEndpoint = root.dataset.leadEndpoint as string;
  const publicKey = root.dataset.publicKey as string;
  const greeting = root.dataset.greeting as string;
  const errorReply = root.dataset.errorReply as string;

  const fab = document.getElementById('cw-fab') as HTMLButtonElement;
  const fabIcons = document.getElementById('cw-fab-icons') as HTMLElement;
  const fabIconClose = document.getElementById('cw-fab-icon-close') as HTMLElement;
  const fabIconVariants = Array.from(document.querySelectorAll('.cw-fab-icon')) as HTMLElement[];
  const fabLabel = document.getElementById('cw-fab-label') as HTMLElement | null;
  const panel = document.getElementById('cw-panel') as HTMLElement;
  const closeBtn = document.getElementById('cw-close') as HTMLButtonElement;
  const messagesEl = document.getElementById('cw-messages') as HTMLElement;
  const inputArea = document.getElementById('cw-input-area') as HTMLElement;
  const input = document.getElementById('cw-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('cw-send') as HTMLButtonElement;
  const leadGate = document.getElementById('cw-lead-gate') as HTMLElement;
  const leadForm = document.getElementById('cw-lead-form') as HTMLFormElement;
  const leadNameInput = document.getElementById('cw-lead-name') as HTMLInputElement;
  const leadPhoneInput = document.getElementById('cw-lead-phone') as HTMLInputElement;
  const leadEmailInput = document.getElementById('cw-lead-email') as HTMLInputElement;
  const leadSubmit = document.getElementById('cw-lead-submit') as HTMLButtonElement;
  const leadError = document.getElementById('cw-lead-error') as HTMLElement;

  const VISITOR_ID_KEY = 'bw_chat_visitor_id';
  const HISTORY_KEY = 'bw_chat_history';
  const LABEL_DISMISSED_KEY = 'bw_chat_label_dismissed';
  const LEAD_NAME_KEY = 'bw_chat_lead_name';
  const LEAD_PHONE_KEY = 'bw_chat_lead_phone';
  const LEAD_EMAIL_KEY = 'bw_chat_lead_email';
  const REQUEST_TIMEOUT_MS = 50000;
  const FAB_ICON_ROTATE_MS = 2600;

  type ChatMessage = { role: 'user' | 'bot'; text: string };

  function getVisitorId(): string {
    let id = localStorage.getItem(VISITOR_ID_KEY);
    if (!id) {
      id = crypto.randomUUID();
      localStorage.setItem(VISITOR_ID_KEY, id);
    }
    return id;
  }

  function loadHistory(): ChatMessage[] {
    try {
      const raw = localStorage.getItem(HISTORY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function saveHistory(history: ChatMessage[]): void {
    localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
  }

  function getLead(): boolean {
    const name = localStorage.getItem(LEAD_NAME_KEY);
    const phone = localStorage.getItem(LEAD_PHONE_KEY);
    const email = localStorage.getItem(LEAD_EMAIL_KEY);
    return !!name && (!!phone || !!email);
  }

  function getTurnstileToken(): string {
    const input = leadForm.querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]');
    return input?.value ?? '';
  }

  function resetTurnstile(): void {
    const turnstile = (window as any).turnstile;
    if (turnstile && typeof turnstile.reset === 'function') {
      turnstile.reset();
    }
  }

  function showChat(): void {
    leadGate.hidden = true;
    messagesEl.hidden = false;
    inputArea.hidden = false;

    const history = loadHistory();
    if (history.length === 0) {
      const greetingMsg: ChatMessage = { role: 'bot', text: greeting };
      history.push(greetingMsg);
      saveHistory(history);
    }
    renderHistory(history);
    input.focus();
  }

  leadForm.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault();

    const name = leadNameInput.value.trim();
    let phoneDigits = leadPhoneInput.value.replace(/\D/g, '');
    if (phoneDigits.length > 11 && phoneDigits.startsWith('55')) {
      phoneDigits = phoneDigits.slice(2);
    }
    const email = leadEmailInput.value.trim();
    const phoneFilled = leadPhoneInput.value.trim().length > 0;
    const emailFilled = email.length > 0;

    if (name.length < 2) {
      leadError.textContent = 'Digite seu nome.';
      leadNameInput.focus();
      return;
    }
    if (!phoneFilled && !emailFilled) {
      leadError.textContent = 'Informe um WhatsApp ou e-mail para contato.';
      leadPhoneInput.focus();
      return;
    }
    if (phoneFilled && (phoneDigits.length < 10 || phoneDigits.length > 11)) {
      leadError.textContent = 'Digite um WhatsApp válido, com DDD.';
      leadPhoneInput.focus();
      return;
    }
    if (emailFilled && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      leadError.textContent = 'Digite um e-mail válido.';
      leadEmailInput.focus();
      return;
    }

    const turnstileToken = getTurnstileToken();
    if (!turnstileToken) {
      leadError.textContent = 'Aguarde a verificação de segurança terminar e tente novamente.';
      return;
    }

    leadError.textContent = '';
    leadSubmit.disabled = true;

    try {
      const response = await fetch(leadEndpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Widget-Key': publicKey,
        },
        body: JSON.stringify({
          visitor_id: getVisitorId(),
          visitor_name: name,
          visitor_phone: phoneFilled ? phoneDigits : undefined,
          visitor_email: emailFilled ? email : undefined,
          turnstile_token: turnstileToken,
        }),
      });

      if (!response.ok) {
        leadError.textContent = 'Não foi possível confirmar seus dados. Tente novamente.';
        resetTurnstile();
        return;
      }

      localStorage.setItem(LEAD_NAME_KEY, name);
      if (phoneFilled) localStorage.setItem(LEAD_PHONE_KEY, phoneDigits);
      if (emailFilled) localStorage.setItem(LEAD_EMAIL_KEY, email);
      track('chat_widget_lead_captured');
      showChat();
    } catch {
      leadError.textContent = 'Não foi possível confirmar seus dados. Verifique sua conexão e tente novamente.';
      resetTurnstile();
    } finally {
      leadSubmit.disabled = false;
    }
  });

  function dismissFabLabel(): void {
    if (!fabLabel) return;
    fabLabel.style.display = 'none';
    localStorage.setItem(LABEL_DISMISSED_KEY, '1');
  }

  let fabIconIndex = 0;
  if (fabIconVariants.length > 1) {
    setInterval(() => {
      fabIconVariants[fabIconIndex]?.classList.remove('cw-fab-icon-active');
      fabIconIndex = (fabIconIndex + 1) % fabIconVariants.length;
      fabIconVariants[fabIconIndex]?.classList.add('cw-fab-icon-active');
    }, FAB_ICON_ROTATE_MS);
  }

  function track(eventName: string): void {
    const gtag = (window as any).gtag;
    if (typeof gtag === 'function') {
      gtag('event', eventName);
    }
  }

  // Astro's scoped <style> only applies its data-astro-cid-* attribute to
  // elements present in the static template. Bubbles are created at runtime,
  // so we copy the attribute from #cw-messages to make .cw-msg/.cw-bubble
  // styles actually apply to them.
  const scopeAttr = Array.from(messagesEl.attributes).find((a) => a.name.startsWith('data-astro-cid-'));

  function applyScope(el: HTMLElement): void {
    if (scopeAttr) el.setAttribute(scopeAttr.name, scopeAttr.value);
  }

  function renderBubble(msg: ChatMessage): void {
    const wrapper = document.createElement('div');
    wrapper.className = `cw-msg cw-msg-${msg.role}`;
    applyScope(wrapper);

    const bubble = document.createElement('div');
    bubble.className = 'cw-bubble';
    bubble.textContent = msg.text;
    applyScope(bubble);
    wrapper.appendChild(bubble);

    messagesEl.appendChild(wrapper);
  }

  function renderHistory(history: ChatMessage[]): void {
    messagesEl.innerHTML = '';
    for (const msg of history) {
      renderBubble(msg);
    }
    scrollToBottom();
  }

  function scrollToBottom(): void {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  let typingEl: HTMLElement | null = null;

  function showTyping(): void {
    const wrapper = document.createElement('div');
    wrapper.className = 'cw-msg cw-msg-bot';
    applyScope(wrapper);

    const typing = document.createElement('div');
    typing.className = 'cw-typing';
    applyScope(typing);
    for (let i = 0; i < 3; i++) {
      const dot = document.createElement('span');
      applyScope(dot);
      typing.appendChild(dot);
    }
    wrapper.appendChild(typing);

    typingEl = wrapper;
    messagesEl.appendChild(wrapper);
    scrollToBottom();
  }

  function hideTyping(): void {
    if (typingEl) {
      typingEl.remove();
      typingEl = null;
    }
  }

  let pendingController: AbortController | null = null;

  function setSending(sending: boolean): void {
    input.disabled = sending;
    sendBtn.disabled = sending;
  }

  async function sendMessage(): Promise<void> {
    const text = input.value.trim();
    if (!text || !sendBtn || sendBtn.disabled) return;

    const history = loadHistory();
    const userMsg: ChatMessage = { role: 'user', text };
    history.push(userMsg);
    saveHistory(history);
    renderBubble(userMsg);
    scrollToBottom();

    input.value = '';
    autoGrow();
    setSending(true);
    showTyping();
    track('chat_widget_message_sent');

    const controller = new AbortController();
    pendingController = controller;
    const timeoutId = setTimeout(() => controller.abort(), REQUEST_TIMEOUT_MS);

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Widget-Key': publicKey,
        },
        body: JSON.stringify({
          visitor_id: getVisitorId(),
          message: text,
        }),
        signal: controller.signal,
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const data = await response.json();
      hideTyping();

      const botMsg: ChatMessage = { role: 'bot', text: data.reply };
      const updatedHistory = loadHistory();
      updatedHistory.push(botMsg);
      saveHistory(updatedHistory);
      renderBubble(botMsg);
      scrollToBottom();
    } catch {
      hideTyping();

      const botMsg: ChatMessage = { role: 'bot', text: errorReply };
      renderBubble(botMsg);
      scrollToBottom();
    } finally {
      clearTimeout(timeoutId);
      pendingController = null;
      setSending(false);
      input.focus();
    }
  }

  function autoGrow(): void {
    input.style.height = 'auto';
    input.style.height = `${Math.min(input.scrollHeight, 104)}px`;
  }

  function getFocusable(): HTMLElement[] {
    if (!leadGate.hidden) {
      return [closeBtn, leadNameInput, leadPhoneInput, leadEmailInput, leadSubmit];
    }
    return [closeBtn, input, sendBtn];
  }

  function isMobileViewport(): boolean {
    return window.matchMedia('(max-width: 480px)').matches;
  }

  function openPanel(): void {
    panel.hidden = false;
    fab.setAttribute('aria-expanded', 'true');
    fab.setAttribute('aria-label', 'Fechar chat');
    fabIcons.style.display = 'none';
    fabIconClose.style.display = '';
    dismissFabLabel();

    if (isMobileViewport()) {
      root.classList.add('cw-panel-open');
      document.body.style.overflow = 'hidden';
    }

    if (getLead()) {
      showChat();
    } else {
      leadGate.hidden = false;
      leadNameInput.focus();
    }

    track('chat_widget_open');
  }

  function closePanel(): void {
    if (pendingController) {
      pendingController.abort();
      pendingController = null;
    }
    panel.hidden = true;
    fab.setAttribute('aria-expanded', 'false');
    fab.setAttribute('aria-label', 'Abrir chat');
    fabIcons.style.display = '';
    fabIconClose.style.display = 'none';
    root.classList.remove('cw-panel-open');
    document.body.style.overflow = '';
    fab.focus();
  }

  fab.addEventListener('click', () => {
    if (panel.hidden) {
      openPanel();
    } else {
      closePanel();
    }
  });

  closeBtn.addEventListener('click', closePanel);

  panel.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      e.preventDefault();
      closePanel();
      return;
    }

    if (e.key === 'Tab') {
      const focusable = getFocusable();
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  input.addEventListener('input', autoGrow);
  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  sendBtn.addEventListener('click', sendMessage);
</script>
