---
const WA_LINK = "https://wa.me/5548998386116?text=Ol%C3%A1!%20Gostaria%20de%20solicitar%20uma%20proposta%20do%20BOT%20BigWorks";

const plans = [
  {
    name: "Starter",
    price: "99",
    description: "Para pequenos negócios que querem automatizar atendimento básico.",
    popular: false,
    color: "#94a3b8",
    features: [
      "1 número WhatsApp",
      "Atendimento por texto",
      "Respostas automáticas",
      "FAQ inteligente",
      "Encaminhamento por setor",
      "Contexto básico",
      "Até 2.000 mensagens/mês",
      "Áudio inteligente (30 min/mês)",
    ],
    missing: [
      "Leitura de imagens e PDF",
      "OCR avançado",
      "Integrações com sistema",
    ],
    ideal: "Pequenos comércios, estéticas, restaurantes",
    cta: "Começar agora",
  },
  {
    name: "Smart",
    price: "297",
    description: "Multimodal completo com integração operacional e IA avançada.",
    popular: true,
    color: "#6366f1",
    features: [
      "Tudo do Starter",
      "Áudio inteligente (300 min/mês)",
      "Leitura de imagens (100/mês)",
      "Leitura de PDF (50/mês)",
      "OCR de documentos",
      "Integração com sistema",
      "Consultas operacionais em tempo real",
      "Pré-agendamentos automáticos",
      "Memória contextual",
      "Até 10.000 mensagens/mês",
    ],
    missing: [],
    ideal: "Oficinas, clínicas, empresas com atendimento operacional",
    cta: "Escolher Smart",
  },
  {
    name: "Pro",
    price: "597",
    priceNote: "a R$997/mês",
    description: "Infraestrutura dedicada, integrações customizadas e IA avançada.",
    popular: false,
    color: "#06b6d4",
    features: [
      "Tudo do Smart",
      "BYOK — chave OpenAI própria",
      "Múltiplos setores e atendentes",
      "Integrações customizadas",
      "Automações personalizadas",
      "Fluxos avançados",
      "Dashboards e relatórios",
      "Prioridade de suporte",
      "Alto volume operacional",
    ],
    missing: [],
    ideal: "Empresas maiores com operação intensa",
    cta: "Solicitar proposta",
  },
];

const setup = {
  title: "Setup / Implantação",
  range: "R$ 300 a R$ 3.000",
  items: [
    "Integrações com ERP/API",
    "Personalização de fluxos",
    "Treinamento da equipe",
    "Configuração de setores",
    "Conectores customizados",
  ],
};
---

<section id="planos" class="py-24 relative overflow-hidden">
  <div class="orb w-80 h-80 opacity-10" style="background: radial-gradient(circle, #6366f1, transparent); top: 0; right: -10%;"></div>

  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-14">
      <div class="section-tag mb-5 mx-auto" style="width: fit-content;">Planos</div>
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: #f1f5f9; line-height: 1.15;">
        Escolha o plano para
        <span class="gradient-text"> sua operação.</span>
      </h2>
      <p style="color: #64748b; font-size: 1rem; margin-top: 0.75rem;">Sem mensagens ilimitadas genéricas — preço justo por uso real.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
      {plans.map((plan) => (
        <div class={`glass-card p-6 flex flex-col gap-5 relative ${plan.popular ? 'plan-popular' : ''} reveal`}>
          {plan.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <div class="px-4 py-1 rounded-full text-xs font-bold" style="background: linear-gradient(135deg, #6366f1, #3b82f6); color: white; font-family: 'Plus Jakarta Sans'; white-space: nowrap;">Mais escolhido</div>
            </div>
          )}

          <div>
            <div style={`font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.8125rem; color: ${plan.color}; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;`}>{plan.name}</div>
            <div class="flex items-end gap-1 mb-2">
              <span style="font-size: 0.875rem; color: #64748b; line-height: 2.2;">R$</span>
              <span style={`font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 2.5rem; color: #f1f5f9; line-height: 1;`}>{plan.price}</span>
              <span style="font-size: 0.875rem; color: #64748b; line-height: 2.2;">/mês</span>
            </div>
            {plan.priceNote && <div style="font-size: 0.75rem; color: #475569; margin-top: -4px;">{plan.priceNote}</div>}
            <p style="font-size: 0.875rem; color: #64748b; line-height: 1.6; margin-top: 0.5rem;">{plan.description}</p>
          </div>

          <div class="h-px" style="background: rgba(255,255,255,0.06);"></div>

          <ul class="flex flex-col gap-2.5 flex-1">
            {plan.features.map((f) => (
              <li class="flex items-start gap-2.5">
                <svg class="flex-shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={plan.popular ? "#6366f1" : plan.color} stroke-width="2.5" aria-hidden="true"><polyline points="20,6 9,17 4,12"/></svg>
                <span style="font-size: 0.875rem; color: #94a3b8;">{f}</span>
              </li>
            ))}
            {plan.missing.map((f) => (
              <li class="flex items-start gap-2.5 opacity-40">
                <svg class="flex-shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                <span style="font-size: 0.875rem; color: #475569;">{f}</span>
              </li>
            ))}
          </ul>

          <div>
            <div style="font-size: 0.6875rem; color: #475569; margin-bottom: 0.875rem;">
              <strong style="color: #64748b;">Ideal para:</strong> {plan.ideal}
            </div>
            <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
              class={plan.popular ? 'btn-primary w-full justify-center' : 'btn-secondary w-full justify-center'}>
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Setup card -->
    <div class="glass-card p-6 flex flex-col md:flex-row gap-6 items-start md:items-center" style="border-color: rgba(245,158,11,0.15);">
      <div class="flex-1">
        <div style="font-size: 0.6875rem; color: #f59e0b; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.375rem;">Implantação</div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 1.125rem; color: #f1f5f9;">{setup.title}</h3>
      </div>
      <div class="flex flex-wrap gap-2">
        {setup.items.map((item) => (
          <div class="px-3 py-1.5 rounded-lg text-xs" style="background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.15); color: #d97706;">{item}</div>
        ))}
      </div>
      <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn-secondary flex-shrink-0">
        Solicitar proposta
      </a>
    </div>
  </div>
</section>
