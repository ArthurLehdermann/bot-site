---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    color: "#6366f1",
    title: "Atendimento automático",
    text: "Responde clientes 24h por dia via WhatsApp, sem intervenção humana para demandas rotineiras.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2" fill="none"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
    color: "#3b82f6",
    title: "Áudio inteligente",
    text: "Transcreve e resume áudios automaticamente. Ninguém mais precisa ouvir minutos de mensagem.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>`,
    color: "#06b6d4",
    title: "Leitura de imagens",
    text: "Interpreta fotos, placas de veículos, documentos e capturas de tela enviadas pelo cliente.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="9" y1="15" x2="15" y2="15"/><line x1="9" y1="11" x2="11" y2="11"/></svg>`,
    color: "#8b5cf6",
    title: "PDF e anexos",
    text: "Lê arquivos enviados pelo cliente, extrai informações relevantes e entende o contexto.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/><path d="M15.54 8.46a5 5 0 010 7.07M8.46 8.46a5 5 0 000 7.07"/></svg>`,
    color: "#f59e0b",
    title: "Integração com sistema",
    text: "Consulta clientes, veículos, ordens de serviço, agendamentos e histórico em tempo real.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>`,
    color: "#ec4899",
    title: "Encaminhamento inteligente",
    text: "Direciona atendimentos automaticamente para o setor correto: financeiro, suporte, oficina ou comercial.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/><line x1="9" y1="10" x2="15" y2="10"/><line x1="9" y1="14" x2="13" y2="14"/></svg>`,
    color: "#10b981",
    title: "Contexto operacional",
    text: "Mantém histórico e contexto do atendimento. O bot sabe com quem está falando e o que já foi tratado.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    color: "#64748b",
    title: "Controle humano",
    text: "Ações críticas como agendamentos e alterações podem exigir confirmação da equipe antes da execução.",
  },
];
---

<section id="funcionalidades" class="py-24 relative" style="background: linear-gradient(180deg, transparent 0%, rgba(var(--rgb-surface-tint), 0.5) 50%, transparent 100%);">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-14">
      <div class="section-tag mb-5 mx-auto" style="width: fit-content;">Funcionalidades</div>
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: var(--color-text-primary); line-height: 1.15;">
        Tudo que sua operação precisa,
        <span class="gradient-text"> integrado ao WhatsApp.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {features.map((f) => (
        <div class="glass-card p-5 flex flex-col gap-3 reveal" style="transition: border-color 0.3s, transform 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style={`background: ${f.color}18; color: ${f.color}; border: 1px solid ${f.color}22;`}>
              <Fragment set:html={f.icon} />
            </div>
            <h3 style={`font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.9375rem; color: var(--color-text-primary);`}>{f.title}</h3>
          </div>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.65;">{f.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
