---
const items = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>`,
    color: "#6366f1",
    title: "Pesquisa automática",
    text: "Ao encerrar o atendimento, o bot pede uma nota de 1 a 5. Ativável por empresa.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    color: "#f59e0b",
    title: "Nota + comentário",
    text: "Registra o score de cada conversa junto de um comentário opcional do cliente.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><line x1="3" y1="21" x2="21" y2="21"/><rect x="5" y="11" width="3" height="7"/><rect x="11" y="6" width="3" height="12"/><rect x="17" y="13" width="3" height="5"/></svg>`,
    color: "#14b8a6",
    title: "CSAT nos painéis",
    text: "Acompanhe a satisfação média por período e canal junto das demais métricas.",
  },
];
---

<section class="py-24 relative">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-12">
      <div class="section-tag mb-5 mx-auto" style="width: fit-content;">Satisfação</div>
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: var(--color-text-primary); line-height: 1.15;">
        Mede a satisfação no fim de
        <span class="gradient-text"> cada conversa.</span>
      </h2>
      <p style="color: var(--color-text-secondary); font-size: 1rem; line-height: 1.7; max-width: 560px; margin: 0.75rem auto 0;">
        Sem ferramenta de pesquisa à parte: o CSAT nasce dentro do próprio atendimento.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {items.map((item) => (
        <div class="glass-card p-5 flex flex-col gap-3 reveal" style="transition: border-color 0.3s, transform 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style={`background: ${item.color}18; color: ${item.color}; border: 1px solid ${item.color}22;`}>
            <Fragment set:html={item.icon} />
          </div>
          <h3 style={`font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.9375rem; color: var(--color-text-primary);`}>{item.title}</h3>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.65;">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
