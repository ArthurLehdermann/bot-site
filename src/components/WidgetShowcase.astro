---
const points = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    color: "#6366f1",
    title: "Pronto em minutos",
    text: "Sua equipe ativa e o chat aparece no seu site. Você não mexe em nada técnico.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    color: "#14b8a6",
    title: "O mesmo atendimento",
    text: "É o bot do WhatsApp, agora também pra quem chega pelo seu site. Uma operação só.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    color: "#f59e0b",
    title: "Resposta na hora",
    text: "O visitante manda a mensagem e já é respondido, sem recarregar a página nem esperar.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    color: "#10b981",
    title: "Protegido contra spam",
    text: "Só funciona no seu site e bloqueia robôs sozinho. Sem mensagem falsa enchendo seu painel.",
  },
];
---

<section class="py-24 relative overflow-hidden">
  <div class="orb w-80 h-80 opacity-08" style="background: radial-gradient(circle, #14b8a6, transparent); top: 20%; right: -10%;"></div>

  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-12">
      <div class="section-tag mb-5 mx-auto" style="width: fit-content;">Atendimento no seu site</div>
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: var(--color-text-primary); line-height: 1.15;">
        Quem entra no seu site
        <span class="gradient-text"> já é atendido.</span>
      </h2>
      <p style="color: var(--color-text-secondary); font-size: 1rem; line-height: 1.7; max-width: 560px; margin: 0.75rem auto 0;">
        O mesmo atendimento do WhatsApp, agora como chat no seu site. Sua equipe ativa — você não precisa de programador.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
      <!-- Browser mockup -->
      <div class="glass-card p-4 reveal">
        <div class="flex items-center gap-2 mb-4 pb-3" style="border-bottom: 1px solid var(--color-border);">
          <span class="w-3 h-3 rounded-full" style="background:#f43f5e;"></span>
          <span class="w-3 h-3 rounded-full" style="background:#f59e0b;"></span>
          <span class="w-3 h-3 rounded-full" style="background:#10b981;"></span>
          <span class="ml-2 px-3 py-1 rounded-md" style="font-size: 0.75rem; color: var(--color-text-faint); background: var(--color-surface); flex: 1;">seusite.com.br</span>
        </div>

        <div class="relative" style="min-height: 190px;">
          <!-- chat panel -->
          <div class="absolute bottom-14 right-2 w-64 rounded-xl overflow-hidden" style="background: var(--color-surface); border: 1px solid var(--color-border); box-shadow: 0 12px 32px rgba(0,0,0,0.25);">
            <div class="px-3 py-2.5" style="background: linear-gradient(135deg, #6366f1, #14b8a6);">
              <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.8125rem; color: #fff;">Atendimento</span>
            </div>
            <div class="p-3 flex flex-col gap-2">
              <div class="self-end px-3 py-2 rounded-2xl rounded-br-sm" style="background:#6366f1; color:#fff; font-size: 0.75rem; max-width: 80%;">Vocês entregam hoje?</div>
              <div class="self-start px-3 py-2 rounded-2xl rounded-bl-sm" style="background: var(--color-bg-card); color: var(--color-text-secondary); font-size: 0.75rem; max-width: 85%; border: 1px solid var(--color-border);">Sim! No seu CEP, a entrega sai ainda hoje. Quer que eu já registre o pedido?</div>
            </div>
          </div>
          <!-- chat button -->
          <div class="absolute bottom-2 right-2 w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, #6366f1, #14b8a6); box-shadow: 0 8px 20px rgba(99,102,241,0.4);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
        </div>
      </div>

      <!-- Points -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {points.map((p) => (
          <div class="glass-card p-4 flex flex-col gap-2.5 reveal" style="transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background: ${p.color}18; color: ${p.color}; border: 1px solid ${p.color}22;`}>
              <Fragment set:html={p.icon} />
            </div>
            <h3 style={`font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.875rem; color: var(--color-text-primary);`}>{p.title}</h3>
            <p style="color: var(--color-text-muted); font-size: 0.8125rem; line-height: 1.6;">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
