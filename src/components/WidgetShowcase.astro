---
const snippet = `<script
  src="https://painel.bot.bigworks.com.br/widget.js"
  data-key="SUA_PUBLIC_KEY"
  async
></script>`;

const points = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    color: "#6366f1",
    title: "Uma tag, qualquer site",
    text: "Cole o script antes do </body>. Sem iframe, sem build, sem backend no seu site.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>`,
    color: "#14b8a6",
    title: "Resolve sozinho",
    text: "A public key identifica a empresa. O widget carrega a configuração certa sem você tocar em código.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    color: "#f59e0b",
    title: "Tempo real",
    text: "As respostas chegam por WebSocket, com fallback automático se a conexão cair.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    color: "#10b981",
    title: "Anti-spam embutido",
    text: "Cloudflare Turnstile e allowlist de domínios (CORS) bloqueiam abuso e uso fora do seu site.",
  },
];
---

<section class="py-24 relative overflow-hidden">
  <div class="orb w-80 h-80 opacity-08" style="background: radial-gradient(circle, #14b8a6, transparent); top: 20%; right: -10%;"></div>

  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-12">
      <div class="section-tag mb-5 mx-auto" style="width: fit-content;">Widget no seu site</div>
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.5rem, 2.5vw, 2.125rem); letter-spacing: -0.03em; color: var(--color-text-primary); line-height: 1.15;">
        Seu atendimento no seu site.
        <span class="gradient-text"> Uma tag.</span>
      </h2>
      <p style="color: var(--color-text-secondary); font-size: 1rem; line-height: 1.7; max-width: 560px; margin: 0.75rem auto 0;">
        O mesmo bot do WhatsApp, agora como chat no seu site. Copie uma linha do painel e cole — pronto.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
      <!-- Snippet -->
      <div class="glass-card p-5 reveal">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-3 h-3 rounded-full" style="background:#f43f5e;"></span>
          <span class="w-3 h-3 rounded-full" style="background:#f59e0b;"></span>
          <span class="w-3 h-3 rounded-full" style="background:#10b981;"></span>
          <span style="font-size: 0.75rem; color: var(--color-text-faint); margin-left: 0.5rem; font-family: monospace;">index.html</span>
        </div>
        <pre style="margin:0; padding:0.5rem 0; font-family: monospace; font-size: 0.8125rem; line-height: 1.7; color: var(--color-text-primary); white-space: pre-wrap; word-break: break-all;">{snippet}</pre>
        <p style="font-size: 0.75rem; color: var(--color-text-faint); margin-top: 0.75rem; line-height: 1.6;">
          A <span style="color: var(--color-text-muted);">public key</span> é gerada no painel ao criar o canal Web.
        </p>
      </div>

      <!-- Points -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {points.map((p) => (
          <div class="glass-card p-4 flex flex-col gap-2.5 reveal" style="transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background: ${p.color}18; color: ${p.color}; border: 1px solid ${p.color}22;`}>
              <Fragment set:html={p.icon} />
            </div>
            <h3 style={`font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.875rem; color: var(--color-text-primary);`}>{p.title}</h3>
            <p style="color: var(--color-text-muted); font-size: 0.8125rem; line-height: 1.6;">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
