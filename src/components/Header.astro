---
const WA_LINK = "https://wa.me/5548998386116?text=Ol%C3%A1!%20Gostaria%20de%20agendar%20uma%20demonstra%C3%A7%C3%A3o%20do%20BOT%20BigWorks";
const LOGIN_URL = "https://painel.bot.bigworks.com.br/login";
---

<header class="fixed top-0 left-0 right-0 z-50" style="background: rgba(6,8,16,0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.06);">
  <div class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline" aria-label="BOT BigWorks">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #6366f1, #3b82f6);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12c0 1.85.5 3.58 1.38 5.06L2 22l4.94-1.38A9.95 9.95 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2z" fill="white" fill-opacity="0.9"/>
          <path d="M9 11.5h6M9 14.5h4" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="17" cy="7" r="3" fill="#06b6d4"/>
          <path d="M16 7l1 1 2-2" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 1rem; color: #f1f5f9; letter-spacing: -0.01em;">
        BOT <span class="gradient-text">BigWorks</span>
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Menu principal">
      <a href="#funcionalidades" style="color: #94a3b8; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#f1f5f9'" onmouseout="this.style.color='#94a3b8'">Funcionalidades</a>
      <a href="#como-funciona" style="color: #94a3b8; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#f1f5f9'" onmouseout="this.style.color='#94a3b8'">Como funciona</a>
      <a href="#planos" style="color: #94a3b8; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#f1f5f9'" onmouseout="this.style.color='#94a3b8'">Planos</a>
      <a href="#faq" style="color: #94a3b8; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#f1f5f9'" onmouseout="this.style.color='#94a3b8'">FAQ</a>
      <a href={LOGIN_URL} style="color: #94a3b8; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#f1f5f9'" onmouseout="this.style.color='#94a3b8'">Entrar</a>
    </nav>

    <!-- CTA -->
    <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary" style="padding: 0.625rem 1.25rem; font-size: 0.875rem;">
      Agendar demonstração
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</header>
